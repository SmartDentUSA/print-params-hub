{
  "redirects": [
    {
      "source": "/base-conhecimento/undefined/:slug*",
      "destination": "/base-conhecimento/f/:slug*",
      "permanent": true
    },
    {
      "source": "/en/knowledge-base/undefined/:slug*",
      "destination": "/en/knowledge-base/f/:slug*",
      "permanent": true
    },
    {
      "source": "/es/base-conocimiento/undefined/:slug*",
      "destination": "/es/base-conocimiento/f/:slug*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/llms.txt",
      "destination": "https://okeogjgqijbfkudfjadz.supabase.co/functions/v1/llms-txt"
    },
    {
      "source": "/.well-known/llms.txt",
      "destination": "https://okeogjgqijbfkudfjadz.supabase.co/functions/v1/llms-txt"
    },
    {
      "source": "/llms-full.txt",
      "destination": "https://okeogjgqijbfkudfjadz.supabase.co/functions/v1/llms-full-txt"
    },
    {
      "source": "/llms-full-:lang.txt",
      "destination": "https://okeogjgqijbfkudfjadz.supabase.co/functions/v1/llms-full-txt?lang=:lang"
    },
    {
      "source": "/docs/:path*",
      "destination": "https://okeogjgqijbfkudfjadz.supabase.co/functions/v1/document-proxy/:path*"
    },
    {
      "source": "/video-sitemap.xml",
      "destination": "/api/video-sitemap"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://okeogjgqijbfkudfjadz.supabase.co/functions/v1/generate-sitemap"
    },
    {
      "source": "/sitemap-conhecimento-pt.xml",
      "destination": "https://okeogjgqijbfkudfjadz.supabase.co/functions/v1/generate-knowledge-sitemap"
    },
    {
      "source": "/sitemap-conhecimento-en.xml",
      "destination": "https://okeogjgqijbfkudfjadz.supabase.co/functions/v1/generate-knowledge-sitemap-en"
    },
    {
      "source": "/sitemap-conhecimento-es.xml",
      "destination": "https://okeogjgqijbfkudfjadz.supabase.co/functions/v1/generate-knowledge-sitemap-es"
    },
    {
      "source": "/sitemap-documentos.xml",
      "destination": "https://okeogjgqijbfkudfjadz.supabase.co/functions/v1/generate-documents-sitemap"
    },
    {
      "source": "/rss.xml",
      "destination": "https://okeogjgqijbfkudfjadz.supabase.co/functions/v1/rss-feed"
    },
    {
      "source": "/feed",
      "destination": "https://okeogjgqijbfkudfjadz.supabase.co/functions/v1/rss-feed"
    },
    {
      "source": "/feed.xml",
      "destination": "https://okeogjgqijbfkudfjadz.supabase.co/functions/v1/rss-feed"
    },
    {
      "source": "/f/:path*",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(googlebot|bingbot|slurp|duckduckbot|baiduspider|yandexbot|facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|applebot|applebot-extended|petalbot|semrushbot|ahrefsbot|dotbot|mj12bot|rogerbot|screaming frog|serpstatbot|gptbot|chatgpt-user|oai-searchbot|perplexitybot|claudebot|anthropic|anthropic-ai|bytespider|ccbot|cohere-ai|google-extended|google-cloudvertexbot|meta-externalagent|meta-externalfetcher|amazonbot|youbot|diffbot|mistralai-user|duckassistbot|kagibot|phindbot|timpibot|iaskbot).*"
        }
      ],
      "destination": "/api/seo-proxy?originalPath=/f/:path*"
    },
    {
      "source": "/f/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(googlebot|bingbot|slurp|duckduckbot|baiduspider|yandexbot|facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|applebot|applebot-extended|petalbot|semrushbot|ahrefsbot|dotbot|mj12bot|rogerbot|screaming frog|serpstatbot|gptbot|chatgpt-user|oai-searchbot|perplexitybot|claudebot|anthropic|anthropic-ai|bytespider|ccbot|cohere-ai|google-extended|google-cloudvertexbot|meta-externalagent|meta-externalfetcher|amazonbot|youbot|diffbot|mistralai-user|duckassistbot|kagibot|phindbot|timpibot|iaskbot).*"
        }
      ],
      "destination": "/api/seo-proxy?originalPath=/:path*"
    },
    {
      "source": "/((?!api/|.*\\.[a-zA-Z0-9]+$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/favicon(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(android-chrome-.*|apple-touch-icon\\.png)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        },
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    },
    {
      "source": "/video-sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/llms-full.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/sitemap-conhecimento-:lang.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/sitemap-documentos.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(rss\\.xml|feed|feed\\.xml)",
      "headers": [
        { "key": "Content-Type", "value": "application/rss+xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=1800" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/agenda",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ]
}
